        , Space
        , Str "graph."
        , Space
        , Str "Different"
        , Space
        , Str "edges"
        , Space
        , Quoted DoubleQuote [ Str "fail" ]
        , Space
        , Str "independently"
        , Space
        , Str "with"
        , Space
        , Str "probability"
        , Space
        , Math InlineMath "p"
        , Str "."
        ]
        ( "../images/networkfig.png" , "" )
    , Space
    , Str "A"
    , Space
    , Str "word"
    ]
, Para
    [ Str "Just"
    , Space
    , Str "a"
    , Space
    , Link ( "" , [] , [] ) [ Str "URL" ] ( "/url/" , "" )
    , Str "."
    ]
, Para
    [ Link
        ( "" , [] , [] )
        [ Str "URL" , Space , Str "and" , Space , Str "title" ]
        ( "/url/" , "title" )
    , Str "."
    ]
, Para
    [ Link
        ( "" , [] , [] )
        [ Str "URL" , Space , Str "and" , Space , Str "title" ]
        ( "/url/" , "title preceded by two spaces" )
    , Str "."
    ]
, Para
    [ Link
        ( "" , [] , [] )
        [ Str "URL" , Space , Str "and" , Space , Str "title" ]
        ( "/url/" , "title preceded by a tab" )
    , Str "."
    ]
, Para
    [ Link
        ( "" , [] , [] )
        [ Str "URL" , Space , Str "and" , Space , Str "title" ]
        ( "/url/" , "title with \"quotes\" in it" )
    ]
, Para
