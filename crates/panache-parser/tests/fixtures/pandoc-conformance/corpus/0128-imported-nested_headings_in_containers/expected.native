[ BulletList
    [ [ Header 1 ( "id" , [] , [] ) [ Str "Heading" ]
      , Plain [ Str "Some" , Space , Str "text" ]
      ]
    ]
, BlockQuote
    [ Header 1 ( "heading" , [] , [] ) [ Str "Heading" ]
    , Para [ Str "Text" ]
    ]
, DefinitionList
    [ ( [ Str "Term" ]
      , [ [ Header 1 ( "heading-1" , [] , [] ) [ Str "Heading" ]
          , Plain [ Str "Some" , Space , Str "text" ]
          ]
        ]
      )
    ]
]
